# Marianatek API credentials (same as Vercel env vars)
MARIANA_CLIENT_ID=your_client_id
MARIANA_REFRESH_TOKEN=your_refresh_token
MEMBERSHIP_ID=your_membership_id

# Server port (default: 3001)
PORT=3001

# CORS: comma-separated allowed origins (default: * allows all)
# Example: https://sydneys-fusion-fitness.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=*
